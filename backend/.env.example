# Remediant 环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库
DATABASE_URL=mysql+aiomysql://remediant:medagent123@localhost:3306/remediant
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# MinIO 文件存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# 阿里百炼 DashScope API (必填)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 模型路由 (仅 dashscope)
INFERENCE_BACKEND=dashscope
EMBEDDING_BACKEND=dashscope
RERANKER_BACKEND=dashscope

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRE_MINUTES=60

# 火山引擎 Doubao (豆包) 多模态 API
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_APP_ID=

# MinIO 报告存储桶
MINIO_BUCKET_REPORTS=remediant-reports
MAX_UPLOAD_SIZE_MB=20

# 调试
DEBUG=true
