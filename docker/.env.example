# Remediant Docker 环境变量配置
# 复制此文件为 .env 并填入实际值
# Docker Compose 会自动从 docker/.env 读取这些变量

# 阿里百炼 DashScope API Key (必填)
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 火山引擎 Doubao 多模态 API Key (可选，语音/报告OCR功能需要)
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_VISION_ENDPOINT=

# JWT 密钥 (生产环境请更换为随机字符串)
JWT_SECRET=your-jwt-secret-here
